# 킨더버스 게임 뷰어 — 환경 변수 예시
# 실제 키는 .env(또는 .env.local)에. .env 는 절대 커밋하지 말 것.
# 🔴 런타임 TTS/이미지 키는 백엔드 프록시 뒤에 숨긴다. 프론트에 raw 키 노출 금지.

# ── TTS (M2~) ─────────────────────────────────────────────
# Naver CLOVA Voice (한국어 유아 친화, 1순위)
CLOVA_VOICE_CLIENT_ID=
CLOVA_VOICE_CLIENT_SECRET=
# (선택) 표현력 중요한 감정 게임 라인 — ElevenLabs
ELEVENLABS_API_KEY=

# ── 교사 이미지 배경제거 폴백 (M3) ────────────────────────
# 기본은 @imgly/background-removal(브라우저 온디바이스, 키 불필요).
# 품질 폴백만 아래 사용.
REMOVE_BG_API_KEY=
REPLICATE_API_TOKEN=

# ── 이미지 생성 폴백 (M3, OpenMoji 미보유 소재만) ─────────
# 스타일 락 + 안전 분류기 거쳐 사용.
IMAGE_GEN_API_KEY=

# ── 저장 (M3, 교사 에셋 / 기관 격리 버킷) ─────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
# 서버 전용 (절대 프론트 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=
