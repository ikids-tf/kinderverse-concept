# KinderVerse AI gateway — server-side keys (never exposed to the browser).
# Copy to `.env` and fill in. With neither key set, the gateway serves an
# offline mock so the app stays fully runnable.

# Anthropic (default provider). Router uses the low/fast tier (claude-haiku-4-5).
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Gemini (secondary text provider + IMAGE generation). Optional.
# 이 키를 넣으면 스튜디오의 실제 이미지/도안 생성이 켜집니다(미설정 시 라벨된 플레이스홀더).
GEMINI_API_KEY=your-gemini-key-here

# OpenAI — 로컬 테스트 전용(charter §1 은 Anthropic+Gemini 기본). 이 키를 넣으면 auto 라우팅이
# 텍스트 생성을 GPT 로 우선 처리합니다(계획·활동지·아이디어 등). 이미지 생성은 그대로 Gemini.
# 프로덕션(Vercel)에는 넣지 마세요 — 미설정 시 기존 Anthropic→Gemini 동작 유지.
# OPENAI_API_KEY=sk-your-openai-key-here

# 이미지 생성 모델(미지정 시 기본값 gemini-2.5-flash-image). 키에서 사용 가능한 id로 교체 가능
# (예: gemini-2.5-flash-image, gemini-3.1-flash-image, gemini-3-pro-image).
# KV_GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# 동영상 생성 모델(Veo, 미지정 시 기본값 veo-3.1-fast-generate-preview — fast·할당량 여유).
# ※ 지우거나 잘못된 id를 넣어도 404 시 서버가 이 키로 쓸 수 있는 Veo 모델을 자동 선택한다.
#   (구 veo-3.0-*·veo-2.0- GA는 신규 키에서 404 나므로 하드코딩보다 '비워두기'를 권장.)
# 고품질 대안(키에 있을 때): veo-3.1-generate-preview. 텍스트/이미지→비디오는 GEMINI_API_KEY 필요.
# KV_GEMINI_VIDEO_MODEL=veo-3.1-fast-generate-preview

# NCP CLOVA Voice (게임 뷰어 나레이션 TTS, task "tts"). 둘 다 넣으면 실제 음성 합성이 켜지고,
# 미설정 시 브라우저 speechSynthesis(ko-KR)로 자동 폴백됩니다. 키는 서버에만 머뭅니다.
# CLOVA_VOICE_CLIENT_ID=your-ncp-clova-client-id
# CLOVA_VOICE_CLIENT_SECRET=your-ncp-clova-client-secret
# 화자(speaker) 오버라이드 — 톤별. 미지정 시 'nara'(여성). 아이 화자 등으로 교체 가능.
# CLOVA_VOICE_SPEAKER_BRIGHT=nara
# CLOVA_VOICE_SPEAKER_CALM=nara

# ─────────────────────────────────────────────────────────────────────────────
# Supabase 클라우드 동기화 (다른 기기에서 같은 자료 보기). 둘 다 비우면 '로컬 전용'으로
# 기존처럼 동작합니다. 채우면 보드/게임/폴더가 공유 1개 공간으로 동기화됩니다.
#  · supabase.com 에서 무료 프로젝트 생성 → Settings → API 에서 값 복사
#  · supabase/schema.sql 을 SQL Editor 에 한 번 실행
#  · VITE_ 접두사 = 브라우저로 노출됨. anon 키는 공개용이라 안전. service_role 키는 절대 넣지 말 것.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional per-tier model overrides.
# KV_ANTHROPIC_MODEL_LOW=claude-haiku-4-5
# KV_ANTHROPIC_MODEL_MID=claude-sonnet-4-6
# KV_ANTHROPIC_MODEL_HIGH=claude-opus-4-8
# KV_GEMINI_MODEL_LOW=gemini-2.5-flash
# KV_GEMINI_MODEL_HIGH=gemini-2.5-pro
# 텍스트(로컬 테스트) 기본은 비용 최소화로 전 tier gpt-4o-mini. 품질 필요 시 상향:
# KV_OPENAI_MODEL_LOW=gpt-4o-mini
# KV_OPENAI_MODEL_MID=gpt-4o-mini
# KV_OPENAI_MODEL_HIGH=gpt-4o-mini
# OpenAI 이미지(gpt-image-1, 로컬 테스트) — 기본 미디엄 품질 + 1024x1024(최저가). 상향 가능:
# KV_OPENAI_IMAGE_MODEL=gpt-image-1
# KV_OPENAI_IMAGE_QUALITY=medium   # low | medium | high | auto
# KV_OPENAI_IMAGE_SIZE=1024x1024   # 1024x1024 | 1536x1024 | 1024x1536 | auto
