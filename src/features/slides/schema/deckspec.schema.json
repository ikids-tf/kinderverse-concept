{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kinderverse.app/schemas/deckspec.schema.json",
  "title": "DeckSpec",
  "description": "킨더버스 슬라이드 생성의 계약. Claude(장표 에이전트)가 생성하고 슬라이드 엔진이 소비한다. 텍스트는 절대 이미지에 굽지 않으며, 레이아웃은 아래 enum 중에서만 고른다. (원본: slides-feature/deckspec.schema.json — src 사본은 deckspec.ts와 1:1.)",
  "type": "object",
  "required": ["category", "theme", "ratio", "ageBand", "title", "slides"],
  "additionalProperties": false,
  "properties": {
    "category": {
      "type": "string",
      "enum": ["lesson", "parent", "admin"],
      "description": "lesson=수업용(아이 대상), parent=부모설명회용, admin=기타행정용. 라우터가 결정."
    },
    "theme": {
      "type": "string",
      "enum": ["milray.light", "milray.warm"],
      "description": "Milray Park 모드. dark 없음."
    },
    "ratio": {
      "type": "string",
      "enum": ["16:9", "4:3"],
      "default": "16:9",
      "description": "기본 16:9. 4:3은 구형 빔프로젝터용(M3)."
    },
    "ageBand": {
      "type": "string",
      "enum": ["3세", "4세", "5세", "혼합"],
      "description": "대상 연령. 콘텐츠 난이도·어휘·문장 길이에 영향."
    },
    "title": {
      "type": "string",
      "description": "덱 제목(파일명·표지에 사용)."
    },
    "language": {
      "type": "string",
      "enum": ["ko", "ja", "en"],
      "default": "ko",
      "description": "콘텐츠 언어. 다국어는 M3."
    },
    "slides": {
      "type": "array",
      "minItems": 1,
      "maxItems": 40,
      "items": { "$ref": "#/definitions/slide" }
    }
  },
  "definitions": {
    "slide": {
      "type": "object",
      "required": ["layout", "blocks"],
      "additionalProperties": false,
      "properties": {
        "layout": {
          "type": "string",
          "enum": ["title", "hero-image", "big-text", "two-column", "bullets", "photo-grid", "quote", "chart"],
          "description": "고정 레이아웃 카탈로그. 이 밖의 자유 레이아웃 금지."
        },
        "blocks": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/block" }
        },
        "speakerNote": {
          "type": "string",
          "description": "교사용 진행 멘트(선택). 슬라이드에는 렌더되지 않음."
        }
      }
    },
    "block": {
      "oneOf": [
        { "$ref": "#/definitions/textBlock" },
        { "$ref": "#/definitions/imageBlock" },
        { "$ref": "#/definitions/bulletsBlock" },
        { "$ref": "#/definitions/chartBlock" }
      ]
    },
    "textBlock": {
      "type": "object",
      "required": ["type", "text"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "enum": ["title", "subtitle", "body", "caption"] },
        "text": { "type": "string" }
      }
    },
    "bulletsBlock": {
      "type": "object",
      "required": ["type", "items"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "enum": ["bullets"] },
        "items": { "type": "array", "minItems": 1, "maxItems": 7, "items": { "type": "string" } }
      }
    },
    "imageBlock": {
      "type": "object",
      "required": ["type", "role", "prompt"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "enum": ["image"] },
        "role": { "type": "string", "enum": ["hero", "inline", "background", "icon"] },
        "prompt": { "type": "string" },
        "characterRef": { "type": "string" },
        "assetId": { "type": ["string", "null"], "default": null }
      }
    },
    "chartBlock": {
      "type": "object",
      "required": ["type", "chartType", "data"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "enum": ["chart"] },
        "chartType": { "type": "string", "enum": ["bar", "line", "pie", "radar"] },
        "data": { "type": "array", "items": { "type": "object" } },
        "caption": { "type": "string" }
      }
    }
  }
}
